NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Sports API Keys (server-side only — optional, providers disabled if missing)
API_FOOTBALL_KEY=
BALLDONTLIE_KEY=
THERACING_API_KEY=
FOIREANN_API_KEY=

# Telegram Bot (create via @BotFather on Telegram)
TELEGRAM_BOT_TOKEN=
# Random string used to verify webhook requests from Telegram.
# Generate with: openssl rand -hex 32
TELEGRAM_WEBHOOK_SECRET=

# App URL (used for webhook registration and Mini App links)
# NEXT_PUBLIC_APP_URL=https://predictsport-rust.vercel.app

# Web Push (VAPID keys — generate with: npx web-push generate-vapid-keys)
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# Product mode (predictsport_full | world_cup_2026_shell | world_cup_2026_archive)
# NEXT_PUBLIC_PRODUCT_MODE=predictsport_full

# CRON_SECRET — Bearer token cron-secret routes verify against.
# Set the same value here, in Vercel project env, AND in Supabase Vault
# (vault.secrets row named 'cron_secret'). pg_cron uses Vault to call
# the routes; Vercel uses the env var for its single daily cron.
# Generate with: openssl rand -hex 32
CRON_SECRET=

# Feature flags (set to "true" to enable)
# NEXT_PUBLIC_FEATURE_CONFIDENCE_ACCORDION=true
